<Window x:Class="GlslWallpaper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:local="clr-namespace:GlslWallpaper"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="174" Width="300"
        SizeToContent="WidthAndHeight" 
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
        Unloaded="Window_Unloaded">
    <Grid Margin="6,6,6,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Row="0" Grid.Column="0" Margin="3,3,3,3">
            <GroupBox.Header>
                <CheckBox Content="Slide" Checked="FlipCheckBox_Checked" Unchecked="FlipCheckBox_Unchecked"/>
            </GroupBox.Header>
            <Grid Margin="3,3,3,3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="AUto"/>
                </Grid.ColumnDefinitions>

                <Label Content="Interval" Grid.Row="0" Grid.Column="0" Margin="3,3,3,3"/>
                <Slider
                    Value="{Binding Path=Value, ElementName=flipIntervalIntegerUpDown, Mode=TwoWay}" Minimum="1" Maximum="300"
                    VerticalAlignment="Center" Grid.Row="0" Grid.Column="1" Margin="3,0,3,0" MinWidth="100"
                    ValueChanged="FlipIntervalSlide_ValueChanged"/>
                <xctk:IntegerUpDown Name="flipIntervalIntegerUpDown" Value="10" Minimum="1" Maximum="300" Grid.Row="0" Grid.Column="2" Margin="3,3,3,3"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Grid.Column="0" Margin="3,3,3,3">
            <GroupBox.Header>
                <CheckBox Content="Animation" Checked="AnimationCheckBox_Checked" Unchecked="AnimationCheckBox_Unchecked"/>
            </GroupBox.Header>
            <Grid Margin="3,3,3,3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="AUto"/>
                </Grid.ColumnDefinitions>

                <CheckBox Content="VSync" Margin="3,3,3,3" Checked="VSyncCheckBox_Checked" Unchecked="VSyncCheckBox_Unchecked"/>

                <Label Content="Framerate" Grid.Row="1" Grid.Column="0"/>
                <Slider
                    x:Name="_fpsSlide"
                    Value="{Binding Path=Value, ElementName=fpsIntegerUpDown, Mode=TwoWay}" Minimum="1" Maximum="60"
                    VerticalAlignment="Center" Grid.Row="1" Grid.Column="1" Margin="3,0,3,0" MinWidth="100"
                    ValueChanged="FpsSlider_ValueChanged"/>
                <xctk:IntegerUpDown Name="fpsIntegerUpDown" Value="60" Minimum="1" Maximum="60" Grid.Row="1" Grid.Column="2"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
